# MeshDash .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Virtual environments
mesh-dash_venv/
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Database (user data — never ship)
data/
*.db
*.sqlite
*.sqlite3

# Secrets and config with local values
.env
.env.*
!.env.example
.mesh-dash_config

# Session and cache
sessions/
.cache/

# Uploads (user data)
plugin_uploads/
pending_plugins/

# Backups
backup/
*.bak
*.bak2
*.old
*.orig

# Archives
*.zip
*.tar.gz

# PHP errors
c2_php_errors.log

# Install flag files
c2_installed.flag

# Community plugins (installed separately)
community_plugins/
community_plugins_suspended/