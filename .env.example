# Environment Variables for Mesh Dash
# Copy this file to .env and fill in your values

# Authentication
AUTH_SECRET_KEY=generate_a_random_64_char_hex_key_here
AUTH_TOKEN_EXPIRE_MINUTES=10080

# Community / Remote Access
COMMUNITY_API_KEY=your_community_api_key_here

# Database
DB_PATH=data/meshtastic_data.db
TASK_DB_PATH=data/tasks.db

# Web Server
WEBSERVER_HOST=0.0.0.0
WEBSERVER_PORT=8181

# Meshtastic Connection
MESHTASTIC_CONNECTION_TYPE=TCP
MESHTASTIC_HOST=192.168.1.100
MESHTASTIC_PORT=4403
MESHTASTIC_SERIAL_PORT=
MESHTASTIC_BLE_MAC=

# MQTT (optional)
MQTT_BROKER=mqtt.meshtastic.org
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TLS=false
MQTT_REGION=EU_868
MQTT_CHANNEL=#
MQTT_NODE_ID=

# MeshCore (optional)
MESHCORE_TRANSPORT=serial
MESHCORE_SERIAL_PORT=
MESHCORE_HOST=
MESHCORE_PORT=4000
